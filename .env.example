# =============================================
# WHERE IS MY FLIGHT — Environment Configuration
# =============================================

# ---- Application ----
APP_NAME="Where Is My Flight"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# ---- PostgreSQL ----
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=wimf
DB_USERNAME=wimf_user
DB_PASSWORD=wimf_secret_change_me

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# ---- Kafka ----
KAFKA_BROKER=kafka:9092
KAFKA_GROUP_ID=wimf-consumer-group
KAFKA_FLIGHT_EVENTS_TOPIC=flight-events
KAFKA_GATE_UPDATES_TOPIC=gate-updates

# ---- Play Framework API ----
PLAY_API_HOST=http://play-api:9000
PLAY_API_TIMEOUT=30

# ---- External Flight Data API ----
# Choose one: aviationstack or flightaware
FLIGHT_API_PROVIDER=aviationstack
AVIATIONSTACK_API_KEY=your_key_here
FLIGHTAWARE_API_KEY=your_key_here
FLIGHTAWARE_API_SECRET=

# ---- Weather API ----
OPENWEATHER_API_KEY=your_key_here
OPENWEATHER_UNITS=metric

# ---- Spark / Prediction ----
SPARK_MASTER=spark://spark-master:7077
SPARK_MODEL_PATH=/opt/spark/models/delay_model
SPARK_CHECKPOINT_DIR=/opt/spark/checkpoints

# ---- Trust Scoring ----
TRUST_SCORE_THRESHOLD=0.65
TRUST_AUTO_APPROVE_THRESHOLD=0.85
TRUST_CORROBORATION_WINDOW_MINUTES=15
TRUST_MIN_CORROBORATIONS=3

# ---- WebSocket ----
WEBSOCKET_PORT=6001
WEBSOCKET_MAX_CONNECTIONS=10000

# ---- Logging ----
LOG_CHANNEL=stack
LOG_LEVEL=debug
